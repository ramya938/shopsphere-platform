# Application Settings
ENVIRONMENT=development
PROJECT_NAME="ShopSphere User Service"
API_V1_STR=/api/v1

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=shopsphere_users

# PostgreSQL connection string for Asyncpg (production / compose)
# For local run without docker, change POSTGRES_HOST to localhost
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/shopsphere_users

# Security Settings
# Generate secure keys using: openssl rand -hex 32
JWT_SECRET_KEY=e83a0adbc87612f0e0c034a706b85bfa17c7689d023bfe4c4246830501867e91
JWT_REFRESH_SECRET_KEY=a7d25e0bc87612f0e0c034a706b85bfa17c7689d023bfe4c4246830501867e9f
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=DEBUG
